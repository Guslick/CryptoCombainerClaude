# =============================================
# CryptoCombainer — Пример конфигурации
# Скопируйте как config.properties и заполните
# =============================================
# Приоритет значений:
#   1. -DKEY=value (JVM system property)
#   2. export KEY=value (env variable)
#   3. config.properties (этот файл)
# =============================================

# === Telegram Bot ===
telegram.bot.token=7420980540:AAENPop_SY3bBVHl8kNxT97Mxazxthvk8Jo
telegram.default.chat.id=-1002453915115
telegram.bot.enabled=true

# === CoinGecko API ===
gecko.api.key=CG-cbW7FEWxc6mZiUAxSY3VDCd9

# === Binance (реальная торговля) ===
binance.api.key=YOUR_BINANCE_API_KEY

# Вариант 1 — путь к .pem файлу:
# binance.private.key.path=/opt/cryptotrader/Ed_PV.pem

# Вариант 2 — содержимое ключа напрямую (без файла):
# binance.private.key.path=-----BEGIN PRIVATE KEY-----\nBASE64_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----

# === Binance Testnet ===
binance.test.api.key=YOUR_TEST_API_KEY
binance.test.private.key.path=/opt/cryptotrader/test-prv-key.pem

# === Web Server (MiniApp) ===
web.server.enabled=true
web.server.port=8080
web.server.host=0.0.0.0
